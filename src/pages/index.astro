<script>
// Waitlist Form Handler
document.getElementById('waitlistForm')?.addEventListener('submit', async function(e) {
    e.preventDefault();

    const namaInput = document.getElementById('namaWaitlist') as HTMLInputElement;
    const emailInput = document.getElementById('emailWaitlist') as HTMLInputElement;
    const waInput = document.getElementById('waWaitlist') as HTMLInputElement;

    const nama = namaInput.value.trim();
    const email = emailInput.value.trim();
    const wa = waInput.value.trim();

    if (!nama || !email || !wa) {
        alert('Mohon isi semua field!');
        return;
    }

    // Disable submit button
    const submitBtn = this.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Menyimpan...';

    try {
        // Call API
        const response = await fetch('/api/waitlist', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                nama,
                email,
                whatsapp: wa,
            }),
        });

        const result = await response.json();

        if (!response.ok) {
            // Show error
            alert(result.error || 'Terjadi kesalahan. Coba lagi ya!');
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
            return;
        }

        // Show success message
        document.getElementById('successMessage')?.classList.remove('hidden');

        // Reset form
        namaInput.value = '';
        emailInput.value = '';
        waInput.value = '';

        // Scroll to success message
        document.getElementById('successMessage')?.scrollIntoView({ behavior: 'smooth', block: 'center' });

        // Hide after 10 seconds
        setTimeout(() => {
            document.getElementById('successMessage')?.classList.add('hidden');
        }, 10000);

        // Re-enable button
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;

    } catch (error) {
        console.error('Error:', error);
        alert('Terjadi kesalahan. Coba lagi ya!');
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
    }
});

// Smooth scroll
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
            const offset = 80;
            const targetPosition = target.offsetTop - offset;
            window.scrollTo({ top: targetPosition, behavior: 'smooth' });
        }
    });
});
</script>

