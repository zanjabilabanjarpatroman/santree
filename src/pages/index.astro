---
// Astro frontmatter
---
<!DOCTYPE html>
<html class="light" lang="id">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Santree - Belajar Islam Jadi Petualangan Seru! | Platform Gamifikasi Phygital</title>
<meta name="description" content="Platform gamifikasi pembelajaran Islam untuk anak 8-12 tahun. Al-Qur'an, Fiqih, Aqidah, Life Skill, Science—jadi quest seru! Kartu fisik, minim screen time. Open source & gratis selamanya."/>
<meta name="keywords" content="Al-Qur'an, ngaji, anak, gamifikasi, phygital, TPQ, Iqro, Qiroati, Ummi, Yanbu'a, Al-Barqy, Fiqih, Aqidah, pembelajaran Islam, Indonesia, open source, minim screen time"/>
<meta name="author" content="Yayasan Zanjabila"/>
<meta name="theme-color" content="#2c6816"/>

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website"/>
<meta property="og:title" content="Santree - Belajar Islam Jadi Petualangan Seru!"/>
<meta property="og:description" content="Platform gamifikasi phygital untuk anak. Al-Qur'an, Fiqih, Aqidah, Life Skill jadi quest seru! Kartu fisik, minim screen time."/>
<meta property="og:site_name" content="Santree"/>

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="Santree - Belajar Islam Jadi Petualangan Seru!"/>
<meta name="twitter:description" content="Platform gamifikasi phygital untuk anak. Al-Qur'an, Fiqih, Aqidah, Life Skill jadi quest seru! Kartu fisik, minim screen time."/>
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&amp;family=Be+Vietnam+Pro:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<style>
        .glass-nav {
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }

        .hero-gradient {
            background: linear-gradient(to bottom, rgba(44, 104, 22, 0.2), rgba(255, 246, 221, 1) 90%);
        }

        /* Fun wiggle animation */
        @keyframes wiggle {
            0%, 100% { transform: rotate(-2deg); }
            50% { transform: rotate(2deg); }
        }

        /* Focus states */
        a:focus-visible, button:focus-visible, input:focus-visible {
            outline: 3px solid #2c6816;
            outline-offset: 2px;
        }
    </style>
</head>
<body class="bg-background text-on-surface font-body antialiased">

<!-- Mobile Navigation -->
<nav class="fixed top-0 w-full z-50 glass-nav bg-background/90 border-b border-primary/10">
    <div class="max-w-7xl mx-auto px-4 py-3 md:py-4 flex justify-between items-center">
        <a href="#home" class="text-xl md:text-2xl font-black text-primary font-headline hover:scale-105 transition-transform">
            🌳 Santree
        </a>

        <!-- Desktop Menu -->
        <div class="hidden md:flex items-center gap-8">
            <a class="text-on-surface hover:text-primary font-semibold transition-colors text-base" href="#features">Fitur</a>
            <a class="text-on-surface hover:text-primary font-semibold transition-colors text-base" href="#how">Cara Main</a>
            <a href="#waitlist" class="bg-primary text-on-primary px-6 py-2.5 rounded-full font-bold hover:bg-primary/90 transition-all hover:shadow-lg">
                Daftar Gratis
            </a>
        </div>

        <!-- Mobile CTA -->
        <a href="#waitlist" class="md:hidden bg-primary text-on-primary px-4 py-2 rounded-full font-bold text-sm hover:bg-primary/90 transition-all">
            Daftar
        </a>
    </div>
</nav>

<main>

<!-- Hero Section - Mobile First -->
<section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20 pb-32 md:pb-40 px-4">
    <!-- Background -->
    <div class="absolute inset-0 z-0">
        <img alt="Hero background" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAZdRPmT9TWOTYK81YwWlPStmcNpG6CqjjA1LV8aHdG22Q0FoCPFxPFyPvFUEVUmxhu2gK3RV6FQZUWSW6TLHp12DRaF7SL6xETkHW6vp7GrGDeb2Cy_sb-sS36dD7qG8T6gMmhe9ozaj2IaJZ4Ykil5j2yu7DkjMTzlH2KQGHKCMwltKGwpU2b6Z57eHyDuvrg89JG8VAzEMI9c9f-_rrNJsaKF8UZ5U1s1V2QB8ZKPf_0Lp_GVYyLYT_A-pEQknbULmfSGWTnu2E"/>
        <div class="absolute inset-0 hero-gradient"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 text-center max-w-4xl mx-auto mb-24 md:mb-0">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 md:px-5 md:py-2.5 rounded-full bg-secondary-light text-primary mb-6 md:mb-8 font-bold text-xs md:text-sm shadow-lg" role="status">
            <span class="text-base md:text-lg">⚡</span>
            <span>Belajar Islam sambil main!</span>
        </div>

        <!-- Heading -->
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-headline font-extrabold text-primary leading-[1.1] mb-6 md:mb-8">
            Bosen Ngaji?<br/>
            <span class="text-tertiary">Santree Aja!</span>
        </h1>

        <!-- Description -->
        <p class="text-lg md:text-xl lg:text-2xl text-on-surface mb-8 md:mb-12 leading-relaxed max-w-2xl mx-auto px-2">
            Al-Qur'an, Fiqih, Aqidah, Adab, Life Skill, sampe Basic Science. Semua jadi quest seru! Kumpulin XP, unlock badge, level up kayak main game! 🎮📖✨
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row justify-center gap-4 md:gap-5 px-4 sm:px-0 mb-8">
            <a href="#waitlist" class="bg-tertiary text-white px-8 py-4 md:px-10 md:py-5 rounded-full font-black text-base md:text-lg hover:bg-tertiary/90 transition-all shadow-xl hover:shadow-2xl hover:scale-105 w-full sm:w-auto">
                🚀 Ikutan Sekarang (Gratis!)
            </a>
            <a href="https://github.com/zanjabilabanjarpatroman/santree" target="_blank" class="flex items-center justify-center gap-2 bg-white/90 text-primary font-bold px-8 py-4 md:px-10 md:py-5 rounded-full text-base md:text-lg hover:bg-white transition-all shadow-lg hover:shadow-xl hover:scale-105 w-full sm:w-auto">
                <span class="material-symbols-outlined">code</span>
                Bantu Bikin Bareng
            </a>
        </div>
    </div>

    <!-- Stats - Mobile Optimized -->
    <div class="absolute bottom-6 md:bottom-8 left-4 right-4 z-20">
        <div class="bg-white/95 backdrop-blur-xl rounded-2xl md:rounded-full p-5 md:p-6 grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 border-2 border-primary/20 shadow-xl max-w-5xl mx-auto hover:scale-105 transition-all">
            <div class="text-center">
                <div class="text-2xl md:text-3xl font-black text-primary">7</div>
                <div class="text-xs font-bold text-on-surface-variant">Kategori Quest</div>
            </div>
            <div class="text-center">
                <div class="text-2xl md:text-3xl font-black text-primary">5</div>
                <div class="text-xs font-bold text-on-surface-variant">Metode BTQ</div>
            </div>
            <div class="text-center">
                <div class="text-2xl md:text-3xl font-black text-tertiary">Minim</div>
                <div class="text-xs font-bold text-on-surface-variant">Screen Time</div>
            </div>
            <div class="text-center">
                <div class="text-2xl md:text-3xl font-black text-secondary">Gratis</div>
                <div class="text-xs font-bold text-on-surface-variant">Selamanya!</div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works - Mobile First -->
<section id="how" class="py-16 md:py-24 bg-surface px-4">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-10 md:mb-16">
            <h2 class="text-3xl md:text-5xl font-headline font-extrabold text-primary mb-4 md:mb-6">
                Gimana Cara Mainnya?
            </h2>
            <p class="text-base md:text-xl text-on-surface-variant max-w-2xl mx-auto">
                Gampang banget! Cuma 3 langkah
            </p>
        </div>

        <!-- Steps -->
        <div class="space-y-6 md:space-y-8 max-w-3xl mx-auto">
            <!-- Step 1 -->
            <div class="bg-white p-8 md:p-10 rounded-3xl shadow-md border-2 border-primary/10 hover:-translate-y-1 transition-transform">
                <div class="flex items-start gap-5 md:gap-6">
                    <div class="text-5xl md:text-6xl">🌱</div>
                    <div>
                        <h3 class="text-xl md:text-2xl font-black text-primary mb-3">Daftar & Pilih Metode</h3>
                        <p class="text-base md:text-lg text-on-surface-variant leading-relaxed">
                            Bikin akun (pake email aja), pilih metode baca tulis Al-Qur'an kamu: Iqro', Qiroati, Ummi, Yanbu'a, atau Al-Barqy!
                        </p>
                    </div>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="bg-white p-8 md:p-10 rounded-3xl shadow-md border-2 border-primary/10 hover:-translate-y-1 transition-transform">
                <div class="flex items-start gap-5 md:gap-6">
                    <div class="text-5xl md:text-6xl">⚔️</div>
                    <div>
                        <h3 class="text-xl md:text-2xl font-black text-primary mb-3">Kerjain Quest Beragam</h3>
                        <p class="text-base md:text-lg text-on-surface-variant leading-relaxed">
                            Baca Al-Qur'an 5 ayat, hafal doa makan, belajar wudhu, bantu ortu, amati fase bulan—ratusan quest seru! Selesaiin, dapet XP!
                        </p>
                    </div>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="bg-white p-8 md:p-10 rounded-3xl shadow-md border-2 border-primary/10 hover:-translate-y-1 transition-transform">
                <div class="flex items-start gap-5 md:gap-6">
                    <div class="text-5xl md:text-6xl">🏆</div>
                    <div>
                        <h3 class="text-xl md:text-2xl font-black text-primary mb-3">Level Up Tanpa HP!</h3>
                        <p class="text-base md:text-lg text-on-surface-variant leading-relaxed">
                            Anak kerjain quest pake kartu fisik (nggak pegang HP!). Ortu tinggal verifikasi dari HP. Makin rajin, level naik dari Batu ke Diamond!
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features - Mobile First -->
<section id="features" class="py-16 md:py-24 px-4 bg-surface-light">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-10 md:mb-16">
            <h2 class="text-3xl md:text-5xl font-headline font-extrabold text-primary mb-4 md:mb-6">
                Ada Apa Aja Sih?
            </h2>
            <p class="text-base md:text-xl text-on-surface-variant max-w-2xl mx-auto">
                Fitur-fitur seru yang bikin kamu ketagihan ngaji!
            </p>
        </div>

        <!-- Feature Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
            <!-- Phygital Feature -->
            <div class="bg-primary text-on-primary p-8 md:p-12 rounded-3xl shadow-lg md:col-span-2 hover:-rotate-1 transition-all overflow-hidden relative">
                <div class="relative z-10">
                    <h3 class="text-2xl md:text-4xl font-black mb-4 md:mb-5">🎴 Kartu Quest Fisik — Minim Screen Time!</h3>
                    <p class="text-base md:text-lg opacity-90 mb-8 md:mb-10 leading-relaxed max-w-2xl">
                        Anak nggak pegang HP! Print kartu quest, anak kerjain langsung (baca Al-Qur'an, shalat, bantu ortu). Ortu tinggal verifikasi pake HP. Gampang, aman, nggak bikin kecanduan gadget!
                    </p>
                    <button class="bg-secondary-light text-primary px-8 py-4 md:px-10 md:py-5 rounded-full font-black text-sm md:text-base transition-all hover:bg-white hover:shadow-lg">
                        Download Kartu Quest →
                    </button>
                </div>
            </div>

            <!-- Daily Quests -->
            <div class="bg-tertiary-light text-white p-8 md:p-10 rounded-3xl shadow-lg hover:rotate-1 transition-all">
                <div class="text-5xl md:text-6xl mb-5">📚</div>
                <h3 class="text-xl md:text-2xl font-black mb-3 md:mb-4">7 Kategori Quest</h3>
                <p class="text-sm md:text-base opacity-90 leading-relaxed">
                    Al-Qur'an, Shalat & Ibadah, Fiqih, Aqidah, Adab & Akhlak, Life Skill, sampai Basic Science. Lengkap abis!
                </p>
            </div>

            <!-- Progress Reports -->
            <div class="bg-white p-8 md:p-10 rounded-3xl shadow-lg border-2 border-primary/10 hover:-rotate-1 transition-all">
                <div class="text-5xl md:text-6xl mb-5">📊</div>
                <h3 class="text-xl md:text-2xl font-black text-primary mb-3 md:mb-4">Laporan Buat Ortu</h3>
                <p class="text-sm md:text-base text-on-surface-variant leading-relaxed">
                    Bapak Ibu bisa pantau perkembangan anak dari dashboard. Lengkap banget!
                </p>
            </div>

            <!-- Badge Collection -->
            <div class="bg-secondary-light p-8 md:p-12 rounded-3xl shadow-lg md:col-span-2 hover:rotate-1 transition-all">
                <h3 class="text-2xl md:text-3xl font-black text-primary mb-3 md:mb-5">🏅 Koleksi Badge dari Semua Kategori</h3>
                <p class="text-base md:text-lg text-primary/80 mb-8 leading-relaxed max-w-2xl">
                    Hafal Al-Fatihah? Badge! Bantu cuci piring? Badge! Belajar kenapa langit biru? Badge juga! Ratusan achievement bisa kamu kumpulin!
                </p>
                <div class="flex gap-4 md:gap-5 flex-wrap">
                    <div class="w-20 h-20 md:w-24 md:h-24 bg-white rounded-2xl shadow-md flex items-center justify-center transition-all hover:scale-125 hover:rotate-12">
                        <div class="text-4xl md:text-5xl">📖</div>
                    </div>
                    <div class="w-20 h-20 md:w-24 md:h-24 bg-white rounded-2xl shadow-md flex items-center justify-center transition-all hover:scale-125 hover:rotate-12">
                        <div class="text-4xl md:text-5xl">🤲</div>
                    </div>
                    <div class="w-20 h-20 md:w-24 md:h-24 bg-white rounded-2xl shadow-md flex items-center justify-center transition-all hover:scale-125 hover:rotate-12">
                        <div class="text-4xl md:text-5xl">🧪</div>
                    </div>
                    <div class="w-20 h-20 md:w-24 md:h-24 bg-white rounded-2xl shadow-md flex items-center justify-center transition-all hover:scale-125 hover:rotate-12">
                        <div class="text-4xl md:text-5xl">💪</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Personas - Mobile First -->
<section class="py-16 md:py-24 px-4 bg-surface">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-10 md:mb-16">
            <h2 class="text-3xl md:text-5xl font-headline font-extrabold text-primary mb-4 md:mb-6">
                Siapa Aja yang Bisa Pake?
            </h2>
            <p class="text-base md:text-xl text-on-surface-variant max-w-2xl mx-auto">
                Dari anak-anak sampe ustadz, semua ada tempatnya!
            </p>
        </div>

        <!-- Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
            <!-- Anak -->
            <div class="bg-white p-8 md:p-10 rounded-3xl shadow-lg border-b-4 border-primary hover:-rotate-1 transition-all">
                <div class="text-6xl md:text-7xl mb-5">🎴</div>
                <div class="text-xs font-black uppercase tracking-wider text-tertiary mb-3">Anak 8-12 Tahun</div>
                <h3 class="text-2xl md:text-3xl font-black text-primary mb-4">"Nggak pegang HP!"</h3>
                <p class="text-sm md:text-base text-on-surface-variant leading-relaxed mb-6">
                    Kerjain quest dari kartu fisik. Baca Al-Qur'an, shalat, bantu ortu, belajar science—semuanya tanpa layar HP!
                </p>
                <div class="flex flex-col gap-3">
                    <div class="flex items-center gap-3 bg-primary/10 p-3 rounded-xl text-xs md:text-sm font-bold text-primary">
                        🎴 Kartu quest fisik
                    </div>
                    <div class="flex items-center gap-3 bg-primary/10 p-3 rounded-xl text-xs md:text-sm font-bold text-primary">
                        ⚡ Minim screen time
                    </div>
                </div>
            </div>

            <!-- Orang Tua -->
            <div class="bg-white p-8 md:p-10 rounded-3xl shadow-lg border-b-4 border-secondary hover:rotate-1 transition-all">
                <div class="text-6xl md:text-7xl mb-5">✅</div>
                <div class="text-xs font-black uppercase tracking-wider text-tertiary mb-3">Orang Tua</div>
                <h3 class="text-2xl md:text-3xl font-black text-primary mb-4">"HP di tangan ortu!"</h3>
                <p class="text-sm md:text-base text-on-surface-variant leading-relaxed mb-6">
                    Tinggal verifikasi quest anak: dengar bacaan, cek shalat, foto hasil karya. Semua progress terekam rapi di dashboard!
                </p>
                <div class="flex flex-col gap-3">
                    <div class="flex items-center gap-3 bg-secondary/10 p-3 rounded-xl text-xs md:text-sm font-bold text-secondary">
                        ✅ Verifikasi mudah
                    </div>
                    <div class="flex items-center gap-3 bg-secondary/10 p-3 rounded-xl text-xs md:text-sm font-bold text-secondary">
                        📊 Tracking lengkap
                    </div>
                </div>
            </div>

            <!-- Ustadz -->
            <div class="bg-white p-8 md:p-10 rounded-3xl shadow-lg border-b-4 border-tertiary hover:-rotate-1 transition-all">
                <div class="text-6xl md:text-7xl mb-5">📚</div>
                <div class="text-xs font-black uppercase tracking-wider text-tertiary mb-3">Ustadz/Ustadzah</div>
                <h3 class="text-2xl md:text-3xl font-black text-primary mb-4">"Ngajar jadi lebih gampang"</h3>
                <p class="text-sm md:text-base text-on-surface-variant leading-relaxed mb-6">
                    Kelola puluhan murid TPQ jadi rapi. Nggak perlu buku catatan manual lagi!
                </p>
                <div class="flex flex-col gap-3">
                    <div class="flex items-center gap-3 bg-tertiary/10 p-3 rounded-xl text-xs md:text-sm font-bold text-tertiary">
                        👥 Kelola kelas mudah
                    </div>
                    <div class="flex items-center gap-3 bg-tertiary/10 p-3 rounded-xl text-xs md:text-sm font-bold text-tertiary">
                        📝 Bank soal lengkap
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Open Source - Mobile First -->
<section class="py-16 md:py-24 px-4">
    <div class="max-w-4xl mx-auto bg-primary text-on-primary p-10 md:p-16 lg:p-20 rounded-3xl shadow-xl text-center hover:rotate-1 transition-all">
        <div class="inline-block px-5 py-2.5 bg-white/20 rounded-full text-xs md:text-sm font-bold mb-6">
            🚧 Masih Dibangun — Mau Bantu?
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-headline font-black mb-6 md:mb-8">
            100% Open Source, Gratis Selamanya
        </h2>
        <p class="text-base md:text-lg lg:text-xl opacity-90 mb-10 md:mb-12 leading-relaxed max-w-2xl mx-auto">
            Santree masih versi pilot. Kalo kamu bisa ngoding, desain, atau bikin konten—yuk bantu bikin bareng! Teknologi pendidikan agama harusnya bisa diakses semua orang.
        </p>
        <a class="inline-flex items-center gap-3 bg-white text-primary px-8 py-4 md:px-10 md:py-5 rounded-full font-black text-base md:text-lg shadow-xl hover:bg-surface-light transition-all hover:scale-105 hover:shadow-2xl" href="https://github.com/zanjabilabanjarpatroman/santree" target="_blank">
            <span class="material-symbols-outlined text-xl">code</span>
            Liat Kodenya di GitHub
        </a>
    </div>
</section>

<!-- Waitlist Section - Mobile First -->
<section class="py-16 md:py-24 px-4" id="waitlist">
    <div class="max-w-5xl mx-auto bg-white rounded-3xl p-8 md:p-12 shadow-2xl border border-primary/5">
        <div class="text-center mb-8 md:mb-12">
            <h2 class="text-3xl md:text-5xl font-headline font-black text-primary mb-4 md:mb-6">
                Mau Coba Duluan?
            </h2>
            <p class="text-sm md:text-lg text-on-surface-variant leading-relaxed max-w-2xl mx-auto">
                Santree masih tahap pilot (beta). Daftar sekarang biar jadi yang pertama nyobain pas launching nanti!
            </p>
        </div>

        <!-- Form -->
        <form id="waitlistForm" class="max-w-lg mx-auto space-y-5" novalidate>
            <div>
                <label for="namaWaitlist" class="sr-only">Nama Lengkap</label>
                <input
                    id="namaWaitlist"
                    name="nama"
                    class="w-full px-6 py-5 rounded-2xl border-2 border-primary/10 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-base md:text-lg bg-surface-light smooth-transition hover:border-primary/20"
                    placeholder="Nama Lengkap"
                    type="text"
                    required
                    autocomplete="name"
                />
            </div>
            <div>
                <label for="emailWaitlist" class="sr-only">Email</label>
                <input
                    id="emailWaitlist"
                    name="email"
                    class="w-full px-6 py-5 rounded-2xl border-2 border-primary/10 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-base md:text-lg bg-surface-light smooth-transition hover:border-primary/20"
                    placeholder="Email"
                    type="email"
                    required
                    autocomplete="email"
                />
            </div>
            <div>
                <label for="waWaitlist" class="sr-only">Nomor WhatsApp</label>
                <input
                    id="waWaitlist"
                    name="whatsapp"
                    class="w-full px-6 py-5 rounded-2xl border-2 border-primary/10 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-base md:text-lg bg-surface-light smooth-transition hover:border-primary/20"
                    placeholder="WhatsApp (08xxx)"
                    type="tel"
                    required
                    autocomplete="tel"
                />
            </div>
            <button
                type="submit"
                class="w-full bg-tertiary text-white py-5 md:py-6 rounded-2xl font-black text-lg md:text-xl hover:bg-tertiary/90 transition-all shadow-lg hover:shadow-2xl hover:scale-[1.02]"
            >
                🚀 Daftar Sekarang (100% Gratis)
            </button>
        </form>

        <!-- Success Message -->
